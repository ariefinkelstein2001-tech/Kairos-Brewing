# ── Shopify (obligatorio) ──────────────────────────────────────────────
# Mismo Shopify que usa Zorbo. Reutiliza las credenciales que ya tienes.
SHOPIFY_STORE_DOMAIN=kairos-brewing.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxx

# ── Opcionales ─────────────────────────────────────────────────────────
# PORT lo inyecta Railway automáticamente; localmente usa 3000 por defecto.
# PORT=3000
# Cambia solo si el vendor en Shopify no es exactamente "Kairos Brewing".
# KAIROS_VENDOR=Kairos Brewing
